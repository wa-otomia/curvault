{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Curvault",
  "version": "0.1.20",
  "identifier": "com.waotomia.curvault",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Curvault",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": ["hudWindow", "mica", "acrylic", "blur"],
          "state": "active",
          "radius": 10
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:; connect-src 'self' ipc:"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1MTI4MDI2NDU1NkZDREEKUldUYS9GWkZKb0FTNWF0M0RsUk5GTGttYXdFYmdmcFRrRVZsd2NBNEJ4S3FSRE1YSzhzZkpRdWQK",
      "endpoints": [
        "https://github.com/wa-otomia/curvault/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Issue and manage IsoApplet smart cards.",
    "longDescription": "Curvault is a desktop workstation for personalizing JavaCard smart cards: manages GlobalPlatform keys in the OS keychain, installs applets via embedded gp, drives pkcs15-init with custom token info (label / manufacturer / serial), generates per-card key + certificate sets according to user-defined profiles, and manages FIDO2 authenticators."
  }
}
