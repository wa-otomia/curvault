{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities granted to the main app window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:app:allow-version",
    "dialog:default",
    "store:default",
    "updater:default",
    "process:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "^https?://" }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "gp",           "cmd": "gp",           "args": true, "sidecar": false },
        { "name": "opensc-tool",  "cmd": "opensc-tool",  "args": true, "sidecar": false },
        { "name": "pkcs15-init",  "cmd": "pkcs15-init",  "args": true, "sidecar": false },
        { "name": "pkcs15-tool",  "cmd": "pkcs15-tool",  "args": true, "sidecar": false },
        { "name": "pkcs11-tool",  "cmd": "pkcs11-tool",  "args": true, "sidecar": false },
        { "name": "openssl",      "cmd": "openssl",      "args": true, "sidecar": false },
        { "name": "fido2-token",  "cmd": "fido2-token",  "args": true, "sidecar": false }
      ]
    }
  ]
}
